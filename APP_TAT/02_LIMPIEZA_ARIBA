            conteo_categoria,
            use_container_width=True,
        )
    else:
        st.info("No existe la columna Categoria Tipo de Compra en el output.")


with st.expander("Diagnóstico de columnas", expanded=False):
    st.dataframe(
        diagnostico_columnas,
        use_container_width=True,
    )


