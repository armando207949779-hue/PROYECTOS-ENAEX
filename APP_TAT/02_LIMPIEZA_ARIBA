with st.expander("Descargas opcionales", expanded=False):
    st.caption(
        "El archivo recomendado es Parquet. CSV y Excel se preparan solo cuando los solicitas."
    )

    col_csv, col_excel = st.columns(2)

    with col_csv:
        preparar_csv = st.button(
            "Preparar CSV",
            use_container_width=True,
        )

        if preparar_csv:
            with st.spinner("Preparando CSV..."):
                st.session_state["ariba_csv_bytes"] = convertir_a_csv_cache(df_output)
                st.session_state["ariba_csv_firma"] = firma_archivo
                st.session_state["ariba_csv_nombre"] = nombre_csv

        if (
            st.session_state.get("ariba_csv_bytes") is not None
            and st.session_state.get("ariba_csv_firma") == firma_archivo
        ):
            st.download_button(
                label="Descargar CSV",
                data=st.session_state["ariba_csv_bytes"],
                file_name=st.session_state["ariba_csv_nombre"],
                mime="text/csv",
                use_container_width=True,
            )

    with col_excel:
        preparar_excel = st.button(
            "Preparar Excel",
            use_container_width=True,
        )

        if preparar_excel:
            with st.spinner("Preparando Excel..."):
                st.session_state["ariba_excel_bytes"] = convertir_a_excel_cache(
                    df_input_limpio=df_input_limpio,
                    df_output=df_output,
                    diagnostico_columnas=diagnostico_columnas,
                )
                st.session_state["ariba_excel_firma"] = firma_archivo
                st.session_state["ariba_excel_nombre"] = nombre_excel

        if (
            st.session_state.get("ariba_excel_bytes") is not None
            and st.session_state.get("ariba_excel_firma") == firma_archivo
        ):
            st.download_button(
                label="Descargar Excel",
                data=st.session_state["ariba_excel_bytes"],
                file_name=st.session_state["ariba_excel_nombre"],
                mime="application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                use_container_width=True,
            )
